import {
  Room,
  RoomEvent,
  ConnectionState,
  Track,
} from 'https://cdn.jsdelivr.net/npm/livekit-client@2.5.9/+esm';

const avatarContainerEl = document.getElementById('avatarContainer');
const avatarEl = document.getElementById('avatar');
const voicebotNameEl = document.getElementById('voicebotName');
const callButtonEl = document.getElementById('callButton');
const statusDotEl = document.getElementById('statusDot');
const statusTextEl = document.getElementById('statusText');
const errorTextEl = document.getElementById('errorText');
const imageAreaEl = document.getElementById('imageArea');
const placeholderEl = document.getElementById('placeholder');
const transcriptListEl = document.getElementById('transcriptList');
const transcriptPlaceholderEl = document.getElementById('transcriptPlaceholder');

const AVATAR_STATUSES = ['idle', 'connecting', 'listening', 'user_speaking', 'bot_speaking', 'processing'];

function setAvatarStatus(status) {
  avatarContainerEl.classList.remove(...AVATAR_STATUSES);
  avatarContainerEl.classList.add(status);
}

const state = {
  config: null,
  room: null,
  connected: false,
  isUserSpeaking: false,
  isBotSpeaking: false,
  audioElements: new Map(),
  imageKeys: new Set(),
  transcripts: [],
};

function setError(message = '') {
  if (!message) {
    errorTextEl.textContent = '';
    errorTextEl.classList.add('hidden');
    return;
  }
  errorTextEl.textContent = message;
  errorTextEl.classList.remove('hidden');
}

function setConnectedStatus(connected) {
  state.connected = connected;
  statusDotEl.classList.toggle('connected', connected);
  statusDotEl.classList.toggle('disconnected', !connected);
  statusTextEl.textContent = connected ? 'Đã kết nối' : 'Đã ngắt kết nối';
  callButtonEl.textContent = connected ? 'Dừng cuộc trò chuyện' : 'Bắt đầu cuộc trò chuyện';
  if (connected) {
    setAvatarStatus('listening');
  } else {
    state.isUserSpeaking = false;
    state.isBotSpeaking = false;
    setAvatarStatus('idle');
  }
}

function setBusyButton(busy) {
  callButtonEl.disabled = busy;
  if (busy) {
    callButtonEl.textContent = 'Đang kết nối...';
    setAvatarStatus('connecting');
  } else {
    callButtonEl.textContent = state.connected ? 'Dừng cuộc trò chuyện' : 'Bắt đầu cuộc trò chuyện';
  }
}

function parseImageUrlsFromText(text) {
  if (!text || typeof text !== 'string') return [];

  const markdownRegex = /!\[[^\]]*\]\((https?:\/\/[^\s)]+)\)/g;
  const imgTagRegex = /<img>(https?:\/\/[^<\s]+)<\/img>/g;
  const directUrlRegex = /(https?:\/\/[^\s]+\.(?:png|jpg|jpeg|webp|gif))(?:\?[^\s]*)?/gi;

  const urls = new Set();

  for (const regex of [markdownRegex, imgTagRegex, directUrlRegex]) {
    let match;
    while ((match = regex.exec(text)) !== null) {
      const url = match[1];
      if (url) urls.add(url);
    }
  }

  return [...urls];
}

function appendImage(url, keyPrefix = 'img') {
  const key = `${keyPrefix}:${url}`;
  if (state.imageKeys.has(key)) return;
  state.imageKeys.add(key);

  placeholderEl.classList.add('hidden');

  const img = document.createElement('img');
  img.className = 'display-image';
  img.src = url;
  img.alt = 'agent image';
  img.loading = 'lazy';

  imageAreaEl.appendChild(img);
  imageAreaEl.scrollTop = imageAreaEl.scrollHeight;
}

function renderTranscripts() {
  transcriptListEl.innerHTML = '';

  if (state.transcripts.length === 0) {
    transcriptPlaceholderEl.classList.remove('hidden');
    transcriptListEl.appendChild(transcriptPlaceholderEl);
    return;
  }

  transcriptPlaceholderEl.classList.add('hidden');

  for (const item of state.transcripts) {
    const transcriptItemEl = document.createElement('div');
    transcriptItemEl.className = `transcript-item ${item.role === 'user' ? 'user' : 'assistant'}`;

    const roleEl = document.createElement('div');
    roleEl.className = 'transcript-role';
    roleEl.textContent = item.role === 'user' ? 'User' : 'Assistant';

    const contentEl = document.createElement('div');
    contentEl.textContent = item.text;

    transcriptItemEl.appendChild(roleEl);
    transcriptItemEl.appendChild(contentEl);
    transcriptListEl.appendChild(transcriptItemEl);
  }

  transcriptListEl.scrollTop = transcriptListEl.scrollHeight;
}

function addOrUpdateTranscript(data) {
  const role = data?.role === 'user' ? 'user' : 'assistant';
  const text = (data?.text || data?.content || '').trim();
  const isComplete = data?.isComplete !== false;

  if (!text) return;

  const last = state.transcripts[state.transcripts.length - 1];
  if (last && last.role === role && last.isComplete === false) {
    last.text = text;
    last.isComplete = isComplete;
    renderTranscripts();
    return;
  }

  state.transcripts.push({
    id: `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
    role,
    text,
    isComplete,
  });
  renderTranscripts();
}

function clearTranscript() {
  state.transcripts = [];
  renderTranscripts();
}

function handleAgentData(payload, participant) {
  if (participant && !participant.identity.startsWith('agent-')) {
    return;
  }

  const text = new TextDecoder().decode(payload);
  let json;

  try {
    json = JSON.parse(text);
  } catch {
    for (const url of parseImageUrlsFromText(text)) {
      appendImage(url, 'text');
    }
    return;
  }

  if (json.type === 'images' && Array.isArray(json.images)) {
    for (const image of json.images) {
      const imageUrl = image?.url || image?.src;
      if (typeof imageUrl === 'string' && imageUrl.startsWith('http')) {
        appendImage(imageUrl, image?.key || 'images');
      }
    }
    return;
  }

  if (json.type === 'transcript') {
    addOrUpdateTranscript(json);

    const transcriptText = json.text || json.content || '';
    for (const url of parseImageUrlsFromText(transcriptText)) {
      appendImage(url, 'transcript');
    }
  }
}

function getRuntimeSessionPayload() {
  return {};
}

async function createSession() {
  const response = await fetch('/api/session', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(getRuntimeSessionPayload()),
  });

  const payload = await response.json().catch(() => ({}));
  if (!response.ok) {
    const message = payload?.error || 'Tạo LiveKit session thất bại';
    throw new Error(message);
  }

  return payload;
}

function clearImageArea() {
  state.imageKeys.clear();
  imageAreaEl.querySelectorAll('.display-image').forEach((el) => el.remove());
  placeholderEl.classList.remove('hidden');
}

function cleanupAudioElements() {
  for (const el of state.audioElements.values()) {
    el.pause();
    el.srcObject = null;
    el.remove();
  }
  state.audioElements.clear();
}

async function disconnectRoom() {
  if (!state.room) return;

  const room = state.room;
  state.room = null;

  try {
    await room.localParticipant.setMicrophoneEnabled(false);
  } catch {
    // Ignore mic close errors.
  }

  room.disconnect();
  cleanupAudioElements();
  setConnectedStatus(false);
}

function updateSpeakingStatus(activeSpeakers) {
  const localSid = state.room?.localParticipant?.sid;
  state.isUserSpeaking = !!localSid && activeSpeakers.some((p) => p.sid === localSid);
  state.isBotSpeaking = activeSpeakers.some((p) => p.identity?.startsWith('agent-'));

  if (state.isUserSpeaking) {
    setAvatarStatus('user_speaking');
  } else if (state.isBotSpeaking) {
    setAvatarStatus('bot_speaking');
  } else if (state.connected) {
    setAvatarStatus('listening');
  }
}

function bindRoomEvents(room) {
  room.on(RoomEvent.ConnectionStateChanged, (connectionState) => {
    const isConnected = connectionState === ConnectionState.Connected;
    setConnectedStatus(isConnected);
  });

  room.on(RoomEvent.ActiveSpeakersChanged, (activeSpeakers) => {
    updateSpeakingStatus(activeSpeakers);
  });

  room.on(RoomEvent.DataReceived, (payload, participant) => {
    handleAgentData(payload, participant);
  });

  room.on(RoomEvent.TrackSubscribed, (track, publication, participant) => {
    if (publication.kind !== Track.Kind.Audio) return;

    const audioEl = track.attach();
    audioEl.autoplay = true;
    audioEl.playsInline = true;
    audioEl.style.display = 'none';
    document.body.appendChild(audioEl);

    state.audioElements.set(track.sid, audioEl);

    participant.on(RoomEvent.TrackUnsubscribed, (unsubscribedTrack) => {
      const existingAudio = state.audioElements.get(unsubscribedTrack.sid);
      if (existingAudio) {
        existingAudio.remove();
        state.audioElements.delete(unsubscribedTrack.sid);
      }
    });
  });

  room.on(RoomEvent.Disconnected, () => {
    cleanupAudioElements();
    setConnectedStatus(false);
    state.room = null;
  });
}

async function startConversation() {
  if (state.connected || state.room) return;

  setError('');
  setBusyButton(true);
  clearImageArea();
  clearTranscript();

  try {
    const session = await createSession();

    if (session.voicebotName) {
      voicebotNameEl.textContent = session.voicebotName;
    }
    if (session.voicebotAvatarUrl) {
      avatarEl.src = session.voicebotAvatarUrl;
    }

    const room = new Room({
      adaptiveStream: true,
      dynacast: true,
    });

    state.room = room;
    bindRoomEvents(room);

    await room.connect(session.livekitUrl, session.participantToken, {
      autoSubscribe: true,
    });

    await room.localParticipant.setMicrophoneEnabled(true);

    setConnectedStatus(true);
  } catch (error) {
    setError(error instanceof Error ? error.message : 'Không thể bắt đầu cuộc trò chuyện');
    await disconnectRoom();
  } finally {
    setBusyButton(false);
  }
}

async function toggleConversation() {
  if (state.connected || state.room) {
    setBusyButton(true);
    await disconnectRoom();
    setBusyButton(false);
    return;
  }

  await startConversation();
}

async function bootstrap() {
  setConnectedStatus(false);
  renderTranscripts();

  const configResponse = await fetch('/api/config');
  const config = await configResponse.json();
  state.config = config;

  voicebotNameEl.textContent = config.voicebotName || 'Voicebot';
  if (config.voicebotAvatarUrl) {
    avatarEl.src = config.voicebotAvatarUrl;
  } else {
    avatarEl.src = 'https://placehold.co/220x220/png?text=Voicebot';
  }

  callButtonEl.addEventListener('click', () => {
    void toggleConversation();
  });
}

window.addEventListener('beforeunload', () => {
  if (state.room) {
    state.room.disconnect();
  }
});

void bootstrap();
