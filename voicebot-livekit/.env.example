# Server
PORT=3099

# External API base URL — REQUIRED (server-side config, not exposed to users)
EXTERNAL_API_BASE_URL=https://api.blaze.vn
EXTERNAL_API_SESSION_PATH=/v1/voicebot-livekit/session

# API Token and Voicebot ID are entered by users via the UI setup panel.
# Do NOT set them here.

# Optional: default participant name for session creation
PARTICIPANT_NAME=web_sample_user
